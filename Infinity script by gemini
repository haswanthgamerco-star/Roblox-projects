-- Safe Data Fetching with null checks
local function getLevel()
    if LocalPlayer and LocalPlayer:FindFirstChild("Data") and LocalPlayer.Data:FindFirstChild("Level") then
        return LocalPlayer.Data.Level.Value
    end
    return 0
end

local function getPoints()
    if LocalPlayer and LocalPlayer:FindFirstChild("Data") and LocalPlayer.Data:FindFirstChild("Points") then
        return LocalPlayer.Data.Points.Value
    end
    return 0
end

local function getCurrentQuest()
    local level = getLevel()
    for _, data in ipairs(QuestDatabase) do
        if level >= data.Min and level <= data.Max then
            return data
        end
    end
    return QuestDatabase[#QuestDatabase]
end

local function hasQuestActive()
    if not LocalPlayer:FindFirstChild("PlayerGui") then return false end
    local main = LocalPlayer.PlayerGui:FindFirstChild("Main")
    if not main then return false end
    local quest = main:FindFirstChild("Quest")
    return quest and quest.Visible == true
end

local function isBuddhaTransformed()
    if not LocalPlayer.Character then return false end
    return LocalPlayer.Character:FindFirstChild("AwakeningState") ~= nil
end

-- Safely shifts Buddha size without animation locking the script engine
local function setBuddhaForm(targetForm)
    if isBuddhaTransformed() ~= targetForm then
        Vim:SendKeyEvent(true, Enum.KeyCode.Z, false, game)
        task.wait(0.2)
        Vim:SendKeyEvent(false, Enum.KeyCode.Z, false, game)
        task.wait(1.4) 
    end
end

-- Force Weapon Equip with proper null checks
local function equipMeleeWeapon()
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    local character = LocalPlayer.Character
    
    if not backpack or not character then return end
    if character:FindFirstChildOfClass("Tool") then return end
    
    for _, tool in pairs(backpack:GetChildren()) do
        if tool:IsA("Tool") and (tool.Name == "Water Kung Fu" or (tool:FindFirstChild("ToolTip") and tool.ToolTip == "Melee")) then
            character.Humanoid:EquipTool(tool)
            break
        end
    end
end

-- Zero-Velocity Safe Gliding (Anti-Cheat Bypass)
local function secureGlide(targetPosition)
    local character = LocalPlayer.Character
    if character and character:FindFirstChild("HumanoidRootPart") then
        character.HumanoidRootPart.Velocity = Vector3.new(0, 0, 0)
        character.HumanoidRootPart.CFrame = CFrame.new(targetPosition)
    end
end

-- Notification System (Fix: Memory leak with stack management)
local function sendNotification(title, message, duration)
    if not _G.NotificationsEnabled then return end
    
    -- Limit notification stack to prevent memory leak
    if #NotificationStack >= MAX_NOTIFICATIONS then
        local oldNotif = table.remove(NotificationStack, 1)
        pcall(function()
            oldNotif:Destroy()
        end)
    end
    
    local NotifGui = Instance.new("ScreenGui")
    NotifGui.Name = "Notification"
    NotifGui.Parent = LocalPlayer:WaitForChild("PlayerGui")
    NotifGui.ResetOnSpawn = false
    
    local CurrentTheme = Themes[_G.CurrentTheme] or Themes.Cyberpunk
    
    local NotifFrame = Instance.new("Frame")
    NotifFrame.Parent = NotifGui
    NotifFrame.BackgroundColor3 = CurrentTheme.Background
    NotifFrame.Position = UDim2.new(0.02, 0, 0.02 + (#NotificationStack * 0.1), 0)
    NotifFrame.Size = UDim2.new(0, 300, 0, 80)
    NotifFrame.BorderSizePixel = 0
    
    local NotifCorner = Instance.new("UICorner")
    NotifCorner.CornerRadius = UDim.new(0, 10)
    NotifCorner.Parent = NotifFrame
    
    local NotifStroke = Instance.new("UIStroke")
    NotifStroke.Color = CurrentTheme.Primary
    NotifStroke.Thickness = 2
    NotifStroke.Parent = NotifFrame
    
    local TitleLabel = Instance.new("TextLabel")
    TitleLabel.Parent = NotifFrame
    TitleLabel.Size = UDim2.new(1, -10, 0, 30)
    TitleLabel.Position = UDim2.new(0, 5, 0, 5)
    TitleLabel.BackgroundTransparency = 1
    TitleLabel.Text = title
    TitleLabel.TextColor3 = CurrentTheme.Primary
    TitleLabel.TextSize = 14
    TitleLabel.Font = Enum.Font.GothamBold
    
    local MessageLabel = Instance.new("TextLabel")
    MessageLabel.Parent = NotifFrame
    MessageLabel.Size = UDim2.new(1, -10, 0, 40)
    MessageLabel.Position = UDim2.new(0, 5, 0, 35)
    MessageLabel.BackgroundTransparency = 1
    MessageLabel.Text = message
    MessageLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
    MessageLabel.TextSize = 12
    MessageLabel.Font = Enum.Font.Gotham
    MessageLabel.TextWrapped = true
    
    table.insert(NotificationStack, NotifGui)
    
    task.wait(duration or 3)
    pcall(function()
        NotifGui:Destroy()
        table.remove(NotificationStack, table.find(NotificationStack, NotifGui))
    end)
end

