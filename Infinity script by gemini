-- Safe Data Fetching
local function getLevel()
    return LocalPlayer.Data.Level.Value
end

local function getCurrentQuest()
    for _, data in ipairs(QuestDatabase) do
        if getLevel() >= data.Min and getLevel() <= data.Max then
            return data
        end
    end
    return QuestDatabase[#QuestDatabase] -- Fallback to highest tracking tier
end

local function hasQuestActive()
    local questUI = LocalPlayer.PlayerGui:FindFirstChild("Main") and LocalPlayer.PlayerGui.Main:FindFirstChild("Quest")
    return questUI and questUI.Visible
end

local function isBuddhaTransformed()
    return LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("AwakeningState") ~= nil
end

-- Safely shifts Buddha size without animation locking the script engine
local function setBuddhaForm(targetForm)
    if isBuddhaTransformed() ~= targetForm then
        Vim:SendKeyEvent(true, Enum.KeyCode.Z, false, game)
        task.wait(0.2)
        Vim:SendKeyEvent(false, Enum.KeyCode.Z, false, game)
        task.wait(1.4) 
    end
end

-- Force Weapon Equip (Filters exclusively for Melee / Water Kung Fu)
local function equipMeleeWeapon()
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    local character = LocalPlayer.Character
    if character and not character:FindFirstChildOfClass("Tool") then
        for _, tool in pairs(backpack:GetChildren()) do
            if tool:IsA("Tool") and (tool.Name == "Water Kung Fu" or tool.ToolTip == "Melee") then
                character.Humanoid:EquipTool(tool)
                break
            end
        end
    end
end

-- Zero-Velocity Safe Gliding (Anti-Cheat Bypass)
local function secureGlide(targetPosition)
    local character = LocalPlayer.Character
    if character and character:FindFirstChild("HumanoidRootPart") then
        character.HumanoidRootPart.Velocity = Vector3.new(0,0,0)
        character.HumanoidRootPart.CFrame = CFrame.new(targetPosition)
    end
end

