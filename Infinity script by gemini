-- Interactive Button Component Factory
local function configureButton(btn, text, offset, globalState)
    btn.Parent = MainFrame
    btn.Position = UDim2.new(0.05, 0, 0, offset)
    btn.Size = UDim2.new(0.9, 0, 0, 45)
    btn.BorderSizePixel = 0
    btn.Font = Enum.Font.SourceSansBold
    btn.TextSize = 14
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 6)
    corner.Parent = btn
    
    local function setVisuals(state)
        if state then
            btn.BackgroundColor3 = Color3.fromRGB(0, 160, 100)
            btn.TextColor3 = Color3.fromRGB(255, 255, 255)
            btn.Text = text .. ": ACTIVE"
        else
            btn.BackgroundColor3 = Color3.fromRGB(180, 40, 40)
            btn.TextColor3 = Color3.fromRGB(255, 255, 255)
            btn.Text = text .. ": DISABLED"
        end
    end
    
    setVisuals(_G[globalState])
    return setVisuals
end

