-- Premium Button Factory with Advanced Effects
local function createPremiumButton(parent, icon, text, yOffset, globalState, color1, color2)
    local btnContainer = Instance.new("Frame")
    btnContainer.Parent = parent
    btnContainer.Position = UDim2.new(0.08, 0, 0, yOffset)
    btnContainer.Size = UDim2.new(0.84, 0, 0, 65)
    btnContainer.BackgroundTransparency = 1
    btnContainer.BorderSizePixel = 0
    
    local btn = Instance.new("TextButton")
    btn.Parent = btnContainer
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.BorderSizePixel = 0
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 15
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 12)
    corner.Parent = btn
    
    local stroke = Instance.new("UIStroke")
    stroke.Thickness = 2
    stroke.Parent = btn
    
    local function setVisuals(state)
        if state then
            btn.BackgroundColor3 = color1
            stroke.Color = color2
            btn.TextColor3 = Color3.fromRGB(255, 255, 255)
            btn.Text = icon .. " " .. text .. " [ACTIVE]"
        else
            btn.BackgroundColor3 = Color3.fromRGB(80, 30, 30)
            stroke.Color = Color3.fromRGB(255, 100, 100)
            btn.TextColor3 = Color3.fromRGB(200, 100, 100)
            btn.Text = icon .. " " .. text .. " [DISABLED]"
        end
    end
    
    -- Premium Hover Effects
    btn.MouseEnter:Connect(function()
        local tweenInfo = TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
        local goal = {BackgroundTransparency = 0.1}
        TweenService:Create(btn, tweenInfo, goal):Play()
        
        if _G[globalState] then
            btn.BackgroundColor3 = Color3.fromRGB(color1.R * 1.2, color1.G * 1.2, color1.B * 1.2)
        end
    end)
    
    btn.MouseLeave:Connect(function()
        if _G[globalState] then
            btn.BackgroundColor3 = color1
        else
            btn.BackgroundColor3 = Color3.fromRGB(80, 30, 30)
        end
    end)
    
    -- Click animation
    btn.MouseButton1Click:Connect(function()
        local tweenInfo = TweenInfo.new(0.1, Enum.EasingStyle.Bounce, Enum.EasingDirection.Out)
        local goal = {Size = UDim2.new(0.9, 0, 1, 0)}
        TweenService:Create(btn, tweenInfo, goal):Play()
        
        task.wait(0.1)
        
        _G[globalState] = not _G[globalState]
        setVisuals(_G[globalState])
        
        local tweenInfo2 = TweenInfo.new(0.1, Enum.EasingStyle.Bounce, Enum.EasingDirection.Out)
        local goal2 = {Size = UDim2.new(1, 0, 1, 0)}
        TweenService:Create(btn, tweenInfo2, goal2):Play()
        
        print((globalState == "AutoFarmActive" and "🌾" or "💪") .. " " .. text .. ": " .. (_G[globalState] and "ENABLED ✓" or "DISABLED ✗"))
    end)
    
    setVisuals(_G[globalState])
    return btn, setVisuals
end

