-- Asynchronous Auto-Stats Engine (Invests points evenly into Melee and Defense)
task.spawn(function()
    while task.wait(5) do
        if _G.AutoStatsActive then
            pcall(function()
                if not LocalPlayer:FindFirstChild("Data") then return end
                if not LocalPlayer.Data:FindFirstChild("Points") then return end
                
                local points = LocalPlayer.Data.Points.Value
                if points > 0 then
                    if ReplicatedStorage:FindFirstChild("Remotes") and ReplicatedStorage.Remotes:FindFirstChild("CommF_") then
                        ReplicatedStorage.Remotes.CommF_:InvokeServer("AddPoint", "Melee", 1)
                        task.wait(0.1)
                        ReplicatedStorage.Remotes.CommF_:InvokeServer("AddPoint", "Defense", 1)
                    end
                end
            end)
        end
    end
end)

-- Core Farming Engine Loop
task.spawn(function()
    if not game:IsLoaded() then game.Loaded:Wait() end
    
    while true do
        task.wait(0.1)
        if _G.AutoFarmActive then
            pcall(function()
                local char = LocalPlayer.Character
                if not char or not char:FindFirstChild("Humanoid") or char.Humanoid.Health <= 0 then return end
                
                local currentRoute = getCurrentQuest()
                
                if not hasQuestActive() then
                    -- STATE 1: ACQUIRE QUEST (Must be a small human to avoid dialog bugs)
                    if isBuddhaTransformed() then setBuddhaForm(false) end
                    secureGlide(currentRoute.Pos)
                    
                    -- Network packet injection to pick up quest instantly
                    if ReplicatedStorage:FindFirstChild("Remotes") and ReplicatedStorage.Remotes:FindFirstChild("CommF_") then
                        ReplicatedStorage.Remotes.CommF_:InvokeServer("StartQuest", currentRoute.Name, currentRoute.Index)
                    end
                    task.wait(0.4)
                else
                    -- STATE 2: COMBAT AUTOMATION (Transforms to giant form)
                    if not isBuddhaTransformed() then setBuddhaForm(true) end
                    
                    local targetEnemy = nil
                    if game.Workspace:FindFirstChild("Enemies") then
                        for _, enemy in pairs(game.Workspace.Enemies:GetChildren()) do
                            if enemy.Name == currentRoute.Enemy and enemy:FindFirstChild("HumanoidRootPart") and enemy:FindFirstChild("Humanoid") and enemy.Humanoid.Health > 0 then
                                targetEnemy = enemy
                                break
                            end
                        end
                    end
                    
                    if targetEnemy then
                        -- Position character 6 studs out to let Buddha's massive attack hitbox shred them safely
                        char.HumanoidRootPart.CFrame = targetEnemy.HumanoidRootPart.CFrame * CFrame.new(0, 0, 6)
                        equipMeleeWeapon()
                        
                        -- Parallel multi-threaded clicking for max Water Kung Fu swing speed
                        task.spawn(function()
                            VirtualUser:CaptureController()
                            VirtualUser:ClickButton1(Vector2.new(0, 0))
                        end)
                    else
                        -- If enemies are dead/not spawned yet, sit safely above the map coordinates
                        secureGlide(currentRoute.Pos + Vector3.new(0, 20, 0))
                    end
                end
            end)
        end
    end
end)

