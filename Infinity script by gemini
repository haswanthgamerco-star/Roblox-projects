-- Safe Data Fetching with null checks
local function getLevel()
    if LocalPlayer and LocalPlayer:FindFirstChild("Data") and LocalPlayer.Data:FindFirstChild("Level") then
        return LocalPlayer.Data.Level.Value
    end
    return 0
end

local function getCurrentQuest()
    local level = getLevel()
    for _, data in ipairs(QuestDatabase) do
        if level >= data.Min and level <= data.Max then
            return data
        end
    end
    return QuestDatabase[#QuestDatabase]
end

local function hasQuestActive()
    if not LocalPlayer:FindFirstChild("PlayerGui") then return false end
    local main = LocalPlayer.PlayerGui:FindFirstChild("Main")
    if not main then return false end
    local quest = main:FindFirstChild("Quest")
    return quest and quest.Visible == true
end

local function isBuddhaTransformed()
    if not LocalPlayer.Character then return false end
    return LocalPlayer.Character:FindFirstChild("AwakeningState") ~= nil
end

-- Safely shifts Buddha size without animation locking the script engine
local function setBuddhaForm(targetForm)
    if isBuddhaTransformed() ~= targetForm then
        Vim:SendKeyEvent(true, Enum.KeyCode.Z, false, game)
        task.wait(0.2)
        Vim:SendKeyEvent(false, Enum.KeyCode.Z, false, game)
        task.wait(1.4) 
    end
end

-- Force Weapon Equip with proper null checks
local function equipMeleeWeapon()
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    local character = LocalPlayer.Character
    
    if not backpack or not character then return end
    if character:FindFirstChildOfClass("Tool") then return end
    
    for _, tool in pairs(backpack:GetChildren()) do
        if tool:IsA("Tool") and (tool.Name == "Water Kung Fu" or (tool:FindFirstChild("ToolTip") and tool.ToolTip == "Melee")) then
            character.Humanoid:EquipTool(tool)
            break
        end
    end
end

-- Zero-Velocity Safe Gliding (Anti-Cheat Bypass)
local function secureGlide(targetPosition)
    local character = LocalPlayer.Character
    if character and character:FindFirstChild("HumanoidRootPart") then
        character.HumanoidRootPart.Velocity = Vector3.new(0, 0, 0)
        character.HumanoidRootPart.CFrame = CFrame.new(targetPosition)
    end
end

